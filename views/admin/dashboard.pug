extends ../layout

block content
  .admin-container
    // Navigation
    nav.admin-nav
      a.admin-nav-brand(href="/admin/dashboard")
        i.fas.fa-magazine
        span Admin Panel
      .admin-nav-links
        a.admin-nav-link.active(href="/admin/dashboard")
          i.fas.fa-tachometer-alt
          | Dashboard
        a.admin-nav-link(href="/admin/users")
          i.fas.fa-users
          | Manage Users
        a.admin-nav-link(href="/admin/users/create")
          i.fas.fa-user-plus
          | Create User
        a.admin-nav-link.logout(href="/admin/logout")
          i.fas.fa-sign-out-alt
          | Logout
    
    // Page Header
    .page-header
      h1
        i.fas.fa-tachometer-alt
        | Dashboard
      p Overview of your digital magazine platform
    
    // Stats
    .stats-grid
      .stat-card
        .stat-icon
          i.fas.fa-users
        .stat-info
          h3 #{stats.totalUsers}
          p Total Users
      .stat-card
        .stat-icon.success
          i.fas.fa-user-check
        .stat-info
          h3 #{stats.activeUsers}
          p Active Users
      .stat-card
        .stat-icon.warning
          i.fas.fa-user-clock
        .stat-info
          h3 #{stats.neverLoggedIn}
          p Never Logged In
      .stat-card
        .stat-icon(style="background: linear-gradient(135deg, #8b5cf6, #6d28d9); box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);")
          i.fas.fa-folder
        .stat-info
          h3 #{stats.totalCollections}
          p Collections
      .stat-card
        .stat-icon(style="background: linear-gradient(135deg, #ec4899, #db2777); box-shadow: 0 4px 12px rgba(236, 72, 153, 0.3);")
          i.fas.fa-images
        .stat-info
          h3 #{stats.totalPhotos}
          p Photos
    
    // Users Table
    .card
      .card-title
        i.fas.fa-users
        | All Users
        span.badge-count #{users.length}
      
      if users.length
        .table-responsive
          table.admin-table
            thead
              tr
                th Email
                th Magazine
                th Status
                th Created
                th Last Login
                th Actions
            tbody
              each user in users
                tr
                  td
                    strong #{user.email}
                  td #{user.magazineName || 'N/A'}
                  td
                    span.badge(class=user.isActive ? 'badge-success' : 'badge-danger')
                      | #{user.isActive ? 'Active' : 'Inactive'}
                  td #{user.createdAt ? new Date(user.createdAt).toLocaleDateString() : 'N/A'}
                  td #{user.lastLogin ? new Date(user.lastLogin).toLocaleDateString() : 'Never'}
                  td
                    .action-buttons
                      a.btn.btn-sm.btn-primary(href=`/admin/users/${user._id}/magazine`, title="Edit Magazine")
                        i.fas.fa-edit
                      button.btn.btn-sm.btn-success(onclick=`generateMagicLinkForUser('${user._id}')`, title="Generate Magic Link")
                        i.fas.fa-magic
                      button.btn.btn-sm.btn-danger(onclick=`deleteUser('${user._id}')`, title="Delete User")
                        i.fas.fa-trash-alt
      else
        .empty-state
          i.fas.fa-users
          h4 No Users Yet
          p Create your first user to get started
    
    // Hidden input for site URL
    input(type="hidden", id="siteUrl", value=siteUrl)

block scripts
  script.
    console.log('📄 Dashboard page loaded');
    
    // ============================================
    // GENERATE MAGIC LINK FOR USER
    // ============================================
    async function generateMagicLinkForUser(userId) {
      if (!userId) {
        showToast('User ID is required', 'error');
        return;
      }
      
      const btn = event.target.closest('button');
      if (!btn) return;
      
      const originalText = btn.innerHTML;
      
      try {
        // Show loading state
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        btn.disabled = true;
        
        console.log('🔑 Generating magic link for user:', userId);
        
        const response = await fetch(`/admin/users/${userId}/magic-link`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        });
        
        if (!response.ok) {
          const errorData = await response.json();
          throw new Error(errorData.error || 'Failed to generate magic link');
        }
        
        const data = await response.json();
        console.log('✅ Magic link generated:', data);
        
        if (data.success && data.magicLink) {
          // Copy to clipboard
          try {
            await navigator.clipboard.writeText(data.magicLink);
            showToast('Magic link copied to clipboard! 🎉', 'success');
          } catch {
            // Fallback for older browsers
            const textArea = document.createElement('textarea');
            textArea.value = data.magicLink;
            document.body.appendChild(textArea);
            textArea.select();
            document.execCommand('copy');
            document.body.removeChild(textArea);
            showToast('Magic link copied to clipboard! 🎉', 'success');
          }
          
          btn.innerHTML = '<i class="fas fa-check"></i>';
          btn.style.background = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';
          
          setTimeout(() => {
            btn.innerHTML = originalText;
            btn.disabled = false;
            btn.style.background = '';
          }, 3000);
        } else {
          throw new Error('Invalid response from server');
        }
      } catch (error) {
        console.error('❌ Error generating magic link:', error);
        showToast('Failed to generate magic link: ' + error.message, 'error');
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    }
    
    // ============================================
    // DELETE USER
    // ============================================
    async function deleteUser(userId) {
      if (!userId) return;
      
      if (!confirm('Are you sure you want to delete this user? This will also delete all their collections and photos.')) {
        return;
      }
      
      try {
        const response = await fetch(`/admin/users/${userId}/delete`, {
          method: 'DELETE'
        });
        
        if (response.ok) {
          showToast('User deleted successfully', 'success');
          setTimeout(() => window.location.reload(), 1000);
        } else {
          throw new Error('Failed to delete user');
        }
      } catch (error) {
        console.error('Error deleting user:', error);
        showToast('Failed to delete user', 'error');
      }
    }
    
    // ============================================
    // EXPOSE FUNCTIONS GLOBALLY
    // ============================================
    window.generateMagicLinkForUser = generateMagicLinkForUser;
    window.deleteUser = deleteUser;