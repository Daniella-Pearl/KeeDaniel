extends ../layout

block content
  .container
    .header
      div
        h1 #{collection.name}
        p #{user.magazineName} - #{user.email}
        if collection.description
          p(style="color:#666;") #{collection.description}
      div
        a.btn.btn-secondary(href=`/admin/users/${user._id}/magazine`) ← Back to Collections
    
    .card
      h3 Collection Settings
      form(action=`/admin/users/${user._id}/collections/${collection._id}/update`, method="POST")
        input(type="text", name="name", value=collection.name, required, style="width:100%; padding:10px; margin-bottom:10px;")
        textarea(name="description", rows="2", style="width:100%; padding:10px; margin-bottom:10px;") #{collection.description}
        .current-thumbnail(style="margin-bottom:10px;")
          strong Current Thumbnail:
          br
          if collection.thumbnailImage
            img(src=collection.thumbnailImage, style="max-width:200px; margin-top:10px;")
          else
            p No thumbnail set
        .upload-thumbnail(style="border:2px dashed #ddd; padding:20px; text-align:center; cursor:pointer; margin-bottom:10px; border-radius:10px;" id="thumbnailUpload")
          i.fas.fa-cloud-upload-alt
          |  Change Thumbnail Image
          input(type="file", id="thumbnailFile", accept="image/*", style="display:none")
        input(type="hidden", name="thumbnailImage", id="thumbnailInput", value=collection.thumbnailImage)
        button.btn.btn-primary(type="submit") Save Collection
    
    .card
      h3 Upload Photos to #{collection.name}
      .upload-area(style="border:2px dashed #ddd; padding:40px; text-align:center; cursor:pointer; margin-bottom:20px; border-radius:10px;" id="uploadArea")
        i.fas.fa-cloud-upload-alt(style="font-size:48px; color:#e94560;")
        p Drag & drop photos here or click to select
        input(type="file", id="fileInput", multiple, accept="image/*", style="display:none")
      
      h3 Photos in this Collection (#{photos.length})
      .gallery(style="display:grid; grid-template-columns:repeat(auto-fill,minmax(250px,1fr)); gap:20px; margin-top:20px;")
        if photos.length
          each photo in photos
            div(style="background:white; border-radius:10px; overflow:hidden; box-shadow:0 2px 5px rgba(0,0,0,0.1);")
              img(src=photo.imageUrl, style="width:100%; height:200px; object-fit:cover;")
              div(style="padding:15px")
                input.photo-caption(
                  type="text", 
                  value=photo.caption || '', 
                  placeholder="Enter caption...", 
                  data-id=photo._id, 
                  style="width:100%; padding:10px; margin-bottom:10px; border:1px solid #ddd; border-radius:5px; font-size:14px;"
                )
                div(style="display:flex; gap:10px;")
                  button.save-caption(data-id=photo._id, style="background:#10b981; color:white; border:none; padding:8px 15px; border-radius:5px; cursor:pointer; flex:1;") Save Caption
                  button.delete-photo(data-id=photo._id, style="background:#dc2626; color:white; border:none; padding:8px 15px; border-radius:5px; cursor:pointer; flex:1;") Delete
        else
          p(style="text-align:center; padding:40px;") No photos yet. Upload some above!
  
  style.
    .upload-area.dragover { border-color: #e94560 !important; background: #fef2f2; }
    .saving { opacity: 0.5; pointer-events: none; }
  
  script.
    const userId = '#{user._id}';
    const collectionId = '#{collection._id}';
    
    // Thumbnail upload
    const thumbnailUpload = document.getElementById('thumbnailUpload');
    const thumbnailFile = document.getElementById('thumbnailFile');
    const thumbnailInput = document.getElementById('thumbnailInput');
    
    thumbnailUpload.onclick = () => thumbnailFile.click();
    
    thumbnailFile.onchange = async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      
      const formData = new FormData();
      formData.append('image', file);
      
      const res = await fetch('/api/upload/image', { method: 'POST', body: formData });
      const data = await res.json();
      
      if (data.success) {
        thumbnailInput.value = data.imageUrl;
        alert('Thumbnail updated. Click "Save Collection" to apply changes.');
      }
    };
    
    // Photo upload
    const uploadArea = document.getElementById('uploadArea');
    const fileInput = document.getElementById('fileInput');
    
    uploadArea.onclick = () => fileInput.click();
    
    uploadArea.ondragover = (e) => {
      e.preventDefault();
      uploadArea.classList.add('dragover');
    };
    
    uploadArea.ondragleave = () => {
      uploadArea.classList.remove('dragover');
    };
    
    uploadArea.ondrop = async (e) => {
      e.preventDefault();
      uploadArea.classList.remove('dragover');
      const files = e.dataTransfer.files;
      await uploadPhotos(files);
    };
    
    fileInput.onchange = async (e) => {
      await uploadPhotos(e.target.files);
    };
    
    async function uploadPhotos(files) {
      for (const file of files) {
        const formData = new FormData();
        formData.append('image', file);
        
        const uploadRes = await fetch('/api/upload/image', { method: 'POST', body: formData });
        const uploadData = await uploadRes.json();
        
        if (uploadData.success) {
          await fetch(`/admin/users/${userId}/collections/${collectionId}/photos`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ imageUrl: uploadData.imageUrl, caption: file.name })
          });
        }
      }
      location.reload();
    }
    
    // Save caption - FIXED: Now properly saves to database
    document.querySelectorAll('.save-caption').forEach(btn => {
      btn.onclick = async () => {
        const photoDiv = btn.closest('div').parentElement.parentElement;
        const input = photoDiv.querySelector('.photo-caption');
        const photoId = input.dataset.id;
        const newCaption = input.value;
        
        // Disable button while saving
        btn.textContent = 'Saving...';
        btn.disabled = true;
        
        try {
          const response = await fetch(`/admin/users/${userId}/collections/${collectionId}/photos/${photoId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ caption: newCaption })
          });
          
          if (response.ok) {
            btn.textContent = 'Saved!';
            setTimeout(() => {
              btn.textContent = 'Save Caption';
              btn.disabled = false;
            }, 2000);
          } else {
            btn.textContent = 'Failed';
            setTimeout(() => {
              btn.textContent = 'Save Caption';
              btn.disabled = false;
            }, 2000);
          }
        } catch (error) {
          console.error('Error:', error);
          btn.textContent = 'Error';
          setTimeout(() => {
            btn.textContent = 'Save Caption';
            btn.disabled = false;
          }, 2000);
        }
      };
    });
    
    // Delete photo
    document.querySelectorAll('.delete-photo').forEach(btn => {
      btn.onclick = async () => {
        if (confirm('Delete this photo?')) {
          await fetch(`/admin/users/${userId}/collections/${collectionId}/photos/${btn.dataset.id}/delete`, { 
            method: 'DELETE' 
          });
          location.reload();
        }
      };
    });
    
    // Auto-save on Enter key press
    document.querySelectorAll('.photo-caption').forEach(input => {
      input.addEventListener('keypress', async (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          const saveBtn = input.parentElement.querySelector('.save-caption');
          if (saveBtn) saveBtn.click();
        }
      });
    });
