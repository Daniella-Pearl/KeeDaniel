extends ../layout

block content
  .create-user-container
    // Navigation
    nav.admin-nav
      a.admin-nav-brand(href="/admin/dashboard")
        i.fas.fa-magazine
        span Admin Panel
      .admin-nav-links
        a.admin-nav-link(href="/admin/dashboard")
          i.fas.fa-tachometer-alt
          | Dashboard
        a.admin-nav-link.active(href="/admin/users")
          i.fas.fa-users
          | Manage Users
        a.admin-nav-link.logout(href="/admin/logout")
          i.fas.fa-sign-out-alt
          | Logout
    
    // Header
    .create-user-header
      .icon-wrap
        i.fas.fa-user-plus
      h1 Create New User
      p Add a new buyer to your digital magazine platform
    
    // Error Message
    if error
      .error-message
        i.fas.fa-exclamation-triangle
        | #{error}
    
    // Success Card
    if success
      .success-card
        .success-icon
          i.fas.fa-check
        h2 🎉 User Created Successfully!
        .user-details
          .detail-item
            i.fas.fa-envelope
            span #{user.email}
          .detail-item
            i.fas.fa-magazine
            span #{user.magazineName}
        
        .magic-link-box
          .magic-label
            i.fas.fa-link
            | Magic Login Link (Share with buyer)
          .input-group
            input(type="text", id="magicLinkInput", value=magicLink, readonly)
            button.btn-copy(onclick="copyMagicLink()")
              i.fas.fa-copy
              | Copy Link
        
        .action-buttons
          a.btn.btn-primary(href=`/admin/users/${user._id}/magazine`)
            i.fas.fa-images
            | Upload Photos
          a.btn.btn-secondary(href="/admin/users/create")
            i.fas.fa-plus
            | Create Another
    
    // Create Form
    if !success
      .create-user-card
        form(action="/admin/users/create", method="POST", id="createUserForm")
          .form-group
            label
              i.fas.fa-envelope
              | Email Address
            .input-icon
              i.fas.fa-envelope
              input(type="email", name="email", required, placeholder="buyer@example.com", autofocus)
          
          .form-group
            label
              i.fas.fa-lock
              | Password
            .input-icon
              i.fas.fa-lock
              input(type="password", name="password", id="password", required, placeholder="Create a secure password", minlength="8")
            .password-strength
              .strength-bar
                .fill#strengthFill
              span.strength-text#strengthText Weak
          
          .form-group
            label
              i.fas.fa-magazine
              | Magazine Name
            .input-icon
              i.fas.fa-magazine
              input(type="text", name="magazineName", placeholder="e.g., John's Wedding Album")
          
          .info-box
            i.fas.fa-info-circle
            .info-content
              strong Tip: 
              | The user will receive a magic login link that expires in 7 days. They can also use password login.
          
          button.btn-submit(type="submit")
            i.fas.fa-user-plus
            | Create User Account

block scripts
  script.
    // Copy magic link
    function copyMagicLink() {
      const input = document.getElementById('magicLinkInput');
      if (!input) return;
      
      input.select();
      
      try {
        navigator.clipboard.writeText(input.value);
        const btn = document.querySelector('.btn-copy');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.innerHTML = originalText;
          btn.classList.remove('copied');
        }, 2000);
      } catch {
        document.execCommand('copy');
        const btn = document.querySelector('.btn-copy');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.innerHTML = originalText;
          btn.classList.remove('copied');
        }, 2000);
      }
    }
    
    // Password strength indicator
    document.addEventListener('DOMContentLoaded', function() {
      const passwordInput = document.getElementById('password');
      const strengthFill = document.getElementById('strengthFill');
      const strengthText = document.getElementById('strengthText');
      
      if (passwordInput && strengthFill && strengthText) {
        passwordInput.addEventListener('input', function() {
          const value = this.value;
          let strength = 0;
          let color = '#ef4444';
          let text = 'Weak';
          
          if (value.length >= 8) strength += 1;
          if (/[a-z]/.test(value) && /[A-Z]/.test(value)) strength += 1;
          if (/\d/.test(value)) strength += 1;
          if (/[^a-zA-Z0-9]/.test(value)) strength += 1;
          
          if (strength <= 1) {
            color = '#ef4444';
            text = 'Weak';
          } else if (strength === 2) {
            color = '#f59e0b';
            text = 'Fair';
          } else if (strength === 3) {
            color = '#3b82f6';
            text = 'Good';
          } else if (strength >= 4) {
            color = '#10b981';
            text = 'Strong';
          }
          
          strengthFill.style.width = `${(strength / 4) * 100}%`;
          strengthFill.style.background = color;
          strengthText.textContent = text;
          strengthText.style.color = color;
        });
      }
    });