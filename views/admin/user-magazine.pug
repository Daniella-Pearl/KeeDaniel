extends ../layout

block content
  .admin-container
    // Hidden input for userId
    input(type="hidden", name="userId", value=user._id)
    
    // Navigation
    nav.admin-nav
      a.admin-nav-brand(href="/admin/dashboard")
        i.fas.fa-magazine
        span Admin Panel
      .admin-nav-links
        a.admin-nav-link(href="/admin/dashboard")
          i.fas.fa-tachometer-alt
          | Dashboard
        a.admin-nav-link.active(href="/admin/users")
          i.fas.fa-users
          | All Users
        a.admin-nav-link.logout(href="/admin/logout")
          i.fas.fa-sign-out-alt
          | Logout
    
    // Page Header
    .page-header
      h1
        i.fas.fa-user-edit
        | #{user.magazineName}
      p
        i.fas.fa-envelope
        | #{user.email}
        span.badge(class=user.isActive ? 'badge-success' : 'badge-danger')
          | #{user.isActive ? 'Active' : 'Inactive'}
    
    // Stats
    - let totalPhotosAll = 0
    each collection in collections
      - totalPhotosAll += collection.photoCount || 0
    
    .stats-grid
      .stat-card
        .stat-icon
          i.fas.fa-folder
        .stat-info
          h3 #{collections.length}
          p Collections
      .stat-card
        .stat-icon.success
          i.fas.fa-images
        .stat-info
          h3 #{totalPhotosAll}
          p Photos
      .stat-card
        .stat-icon(class=user.isActive ? 'success' : 'danger')
          i.fas.fa-circle
        .stat-info
          h3 #{user.isActive ? 'Active' : 'Inactive'}
          p Account Status
    
    // Account Settings
    .card
      .card-title
        i.fas.fa-cog
        | Account Settings
      form(action=`/admin/users/${user._id}/update`, method="POST", id="accountForm")
        .form-group
          label
            i.fas.fa-magazine
            | Magazine Name
            span.required *
          input(type="text", name="magazineName", value=user.magazineName, placeholder="Enter magazine name")
        .form-group
          label.toggle-switch
            input(type="checkbox", name="isActive", checked=user.isActive)
            span.toggle-label Active Account (User can login)
        .form-row
          button.btn.btn-primary(type="submit")
            i.fas.fa-save
            | Save Changes
          a.btn.btn-outline(href="/admin/users")
            i.fas.fa-arrow-left
            | Back to Users
    
    // Magic Link
    .card
      .card-title
        i.fas.fa-link
        | Share Access
      button.btn.btn-success#generateMagicLinkBtn(onclick="generateMagicLink()")
        i.fas.fa-magic
        | Generate & Copy Magic Link
      .magic-link-box#magicLinkBox(style="display: none;")
        i.fas.fa-copy(style="color: var(--success); margin-right: 8px;")
        strong Magic Link (share with buyer):
        input(type="text", id="magicLinkInput", readonly)
        small.info
          i.fas.fa-info-circle
          | This link expires in 7 days
    
    // Create Collection
    .card
      .card-title
        i.fas.fa-plus-circle
        | Create New Collection
      form(action=`/admin/users/${user._id}/collections`, method="POST", id="collectionForm")
        .form-group
          label
            i.fas.fa-folder
            | Collection Name
            span.required *
          input(type="text", name="name", placeholder="e.g., Wedding Day, Reception Party")
        .form-group
          label
            i.fas.fa-align-left
            | Description
          textarea(name="description", rows="2", placeholder="Add a brief description...")
        .form-group
          label
            i.fas.fa-image
            | Thumbnail Image
            span(style="font-weight: 400; color: var(--gray); font-size: 12px; margin-left: 8px;") (Optional)
          .upload-area#thumbnailUpload
            i.fas.fa-cloud-upload-alt
            p Click or drag to upload thumbnail
            span.hint PNG, JPG up to 10MB
            input(type="file", id="thumbnailFile", accept="image/*", style="display:none")
          img#thumbnailPreview(style="max-width: 100%; max-height: 150px; display: none; margin-top: var(--spacing-md); border-radius: var(--radius-md);")
          input(type="hidden", name="thumbnailImage", id="thumbnailInput")
        button.btn.btn-primary(type="submit")
          i.fas.fa-folder-plus
          | Create Collection
    
    // Collections List
    .card
      .card-title
        i.fas.fa-layer-group
        | Collections
        span.badge-count #{collections.length}
      
      if collections.length
        .collections-grid
          each collection in collections
            .collection-card
              .collection-image-wrap
                if collection.thumbnailImage
                  img.collection-image(src=collection.thumbnailImage, alt=collection.name)
                else
                  .collection-image-placeholder
                    i.fas.fa-images
                .collection-overlay
                  span.photo-count-badge
                    i.fas.fa-camera
                    | #{collection.photoCount || 0} photos
              .collection-info
                h4 #{collection.name}
                if collection.description
                  p.description #{collection.description}
                .collection-actions
                  a.btn.btn-primary(href=`/admin/users/${user._id}/collections/${collection._id}`)
                    i.fas.fa-images
                    | Manage
                  form(action=`/admin/users/${user._id}/collections/${collection._id}/delete`, method="POST", onsubmit="return confirmDelete('Delete this collection and all its photos?')")
                    input(type="hidden", name="_method", value="DELETE")
                    button.btn.btn-danger(type="submit")
                      i.fas.fa-trash-alt
                      | Delete
      else
        .empty-state
          i.fas.fa-folder-open
          h4 No Collections Yet
          p Create your first collection to start uploading photos.

block scripts
  script.
    console.log('📄 Admin magazine page loaded');