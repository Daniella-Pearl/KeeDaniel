doctype html
html
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Account Inactive - Digital Magazine
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; }
      
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        min-height: 100vh;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        position: relative;
        overflow: hidden;
      }
      
      /* Animated background circles */
      body::before {
        content: '';
        position: absolute;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(233,69,96,0.1) 0%, transparent 70%);
        top: -100px;
        left: -100px;
        border-radius: 50%;
        animation: float 20s ease-in-out infinite;
      }
      
      body::after {
        content: '';
        position: absolute;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(233,69,96,0.05) 0%, transparent 70%);
        bottom: -150px;
        right: -150px;
        border-radius: 50%;
        animation: float 15s ease-in-out infinite reverse;
      }
      
      @keyframes float {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(30px, 30px); }
      }
      
      .inactive-container {
        max-width: 500px;
        width: 100%;
        z-index: 10;
        animation: slideUp 0.6s ease-out;
      }
      
      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      
      .inactive-card {
        background: rgba(255, 255, 255, 0.98);
        border-radius: 32px;
        padding: 50px 40px;
        text-align: center;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(10px);
      }
      
      .icon-wrapper {
        margin-bottom: 30px;
      }
      
      .icon-circle {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        animation: pulse 2s ease-in-out infinite;
      }
      
      @keyframes pulse {
        0%, 100% {
          transform: scale(1);
          box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4);
        }
        50% {
          transform: scale(1.05);
          box-shadow: 0 0 0 15px rgba(239, 68, 68, 0);
        }
      }
      
      .icon-circle i {
        font-size: 48px;
        color: #dc2626;
      }
      
      h1 {
        font-size: 32px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 15px;
      }
      
      .message {
        color: #6c757d;
        font-size: 16px;
        line-height: 1.6;
        margin-bottom: 30px;
      }
      
      .contact-info {
        background: #f8f9fa;
        border-radius: 20px;
        padding: 20px;
        margin: 25px 0;
        text-align: left;
      }
      
      .contact-info p {
        color: #495057;
        font-size: 14px;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      
      .contact-info i {
        width: 25px;
        color: #e94560;
        font-size: 16px;
      }
      
      .divider {
        display: flex;
        align-items: center;
        margin: 25px 0;
        color: #dee2e6;
      }
      
      .divider::before,
      .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e9ecef;
      }
      
      .divider span {
        padding: 0 15px;
        font-size: 12px;
        color: #adb5bd;
      }
      
      .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: linear-gradient(135deg, #e94560 0%, #c72a48 100%);
        color: white;
        padding: 14px 28px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        font-size: 16px;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        margin-top: 10px;
      }
      
      .btn-back:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(233, 69, 96, 0.3);
      }
      
      .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: white;
        color: #6c757d;
        padding: 12px 24px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 500;
        font-size: 14px;
        transition: all 0.3s ease;
        border: 1px solid #dee2e6;
        margin-left: 10px;
      }
      
      .btn-secondary:hover {
        border-color: #e94560;
        color: #e94560;
      }
      
      .status-badge {
        display: inline-block;
        background: #fee2e2;
        color: #dc2626;
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 20px;
      }
      
      @media (max-width: 768px) {
        .inactive-card {
          padding: 35px 25px;
        }
        h1 { font-size: 26px; }
        .btn-back, .btn-secondary { padding: 10px 20px; font-size: 14px; }
      }
  
  body
    .inactive-container
      .inactive-card
        .icon-wrapper
          .icon-circle
            i.fas.fa-lock
        
        .status-badge
          i.fas.fa-exclamation-triangle
          |  Account Deactivated
        
        h1 Access Restricted
        
        .message
          p Your magazine account has been temporarily deactivated.
          br
          strong #{userName || 'This account'} is currently inactive.
        
        .contact-info
          p
            i.fas.fa-envelope
            | Contact your magazine provider for assistance
          p
            i.fas.fa-clock
            | Response time: Usually within 24 hours
          p
            i.fas.fa-shield-alt
            | Account security is our priority
        
        .divider
          span What would you like to do?
        
        a.btn-back(href="javascript:history.back()")
          i.fas.fa-arrow-left
          | Go Back
        
        a.btn-secondary(href="/login")
          i.fas.fa-sign-in-alt
          | Try Another Account
    
